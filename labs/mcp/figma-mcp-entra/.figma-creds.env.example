# figma-mcp-entra lab credentials — TEMPLATE
#
# Copy to .figma-creds.env (gitignored — see .gitignore), fill in your values,
# then source it before running the runbook:
#   cp .figma-creds.env.example .figma-creds.env
#   source .figma-creds.env
#
# Never commit a populated copy. Rotate any secret that reaches a shared machine.

# --- Entra (Layer A) — the app registration from Step 1 ---
export ENTRA_TENANT_ID=YOUR_TENANT_ID
export ENTRA_CLIENT_ID=YOUR_APP_CLIENT_ID
export ENTRA_CLIENT_SECRET=YOUR_APP_CLIENT_SECRET
export ENTRA_API_SCOPE="api://${ENTRA_CLIENT_ID}/agentgateway"

# --- Figma (Layer B) — the Figma OAuth app from Step 1 ---
export FIGMA_CLIENT_ID=YOUR_FIGMA_CLIENT_ID
export FIGMA_CLIENT_SECRET=YOUR_FIGMA_CLIENT_SECRET

# --- Gateway ---
export ENTRA_GATEWAY_HOST=YOUR_GATEWAY_HOST    # e.g. mcp-entra.glootest.com

# --- Derived Entra endpoints ---
export ENTRA_AUTHORITY="https://login.microsoftonline.com/${ENTRA_TENANT_ID}"
export ENTRA_JWKS_URL="${ENTRA_AUTHORITY}/discovery/v2.0/keys"
