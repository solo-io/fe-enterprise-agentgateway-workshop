{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["team", "endpoints"],
  "properties": {
    "global": {"type": "object"},
    "team": {"type": "string", "minLength": 1, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"},
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "path", "targets"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"},
          "type": {"enum": ["mcp"]},
          "path": {"type": "string", "pattern": "^/"},
          "toolMode": {"enum": ["search", "code"]},
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "host", "port"],
              "properties": {
                "name": {"type": "string"},
                "host": {"type": "string"},
                "port": {"type": "integer"},
                "protocol": {"enum": ["StreamableHTTP"]}
              }
            }
          }
        }
      }
    }
  }
}
